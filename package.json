{
  "name": "osm-verkehrswende-org",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24 <25",
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "bun run --parallel dev:*",
    "dev:astro": "astro dev",
    "dev:watch-project-keys": "bun run cms/scripts/watchProjectKeys.ts",
    "start": "bun run dev",
    "build": "astro build",
    "build:local": "ASTRO_OUTPUT_MODE=static astro build",
    "preview": "ASTRO_OUTPUT_MODE=static astro preview --open",
    "astro": "astro",
    "extract-project-keys": "bun run cms/scripts/extractProjectKeys.ts && prettier 'cms/extractedProjectKeys.ts' --write",
    "generate-types": "astro sync --verbose --force && bun run generate-types:highlightError",
    "generate-types:highlightError": "echo -e '\\033[47;30mSHOW TYPES `any`\\033[0m' && cat ./.astro/content.d.ts | grep -B 1 ': any'",
    "generate-types:full": "astro sync --verbose && bun run generate-types:highlightError && echo -e '\\033[47;30mSHOW FULL GENERATED TYPE FILE\\033[0m' && cat ./.astro/content.d.ts",
    "type-check": "astro check && tsc --skipLibCheck --noEmit",
    "lint": "oxlint --fix src cms",
    "format": "prettier --ignore-path .gitignore '{src,cms}/**/*.+(ts|js|tsx|astro)' --write",
    "format:all": "prettier --ignore-path .gitignore '{src,cms}/**/*.+(ts|js|tsx|astro|mdx)' --write",
    "check": "bun run type-check && bun run format && bun run lint",
    "cqi:createPmtiles": "bun run cqi:createPmtiles:pmTiles && bun run cqi:createPmtiles:upload",
    "cqi:createPmtiles:pmTiles": "node ./scripts/cqi/createPmtiles/createPmtiles.js",
    "cqi:createPmtiles:upload": "node ./scripts/cqi/createPmtiles/upload.js",
    "cqi:createMbtiles": "node ./scripts/cqi/createMbtiles/createMbtiles.js",
    "cqi:routing": "bun run cqi:routing:geojson && bun run cqi:routing:graph && bun run cqi:routing:copy",
    "cqi:routing:geojson": "chmod +x ./scripts/cqi/routing/createGeojson.sh && ./scripts/cqi/routing/createGeojson.sh",
    "cqi:routing:graph": "chmod +x ./scripts/cqi/routing/createGraph.sh && ./scripts/cqi/routing/createGraph.sh",
    "cqi:routing:copy": "chmod +x ./scripts/cqi/routing/copyPublicFiles.sh && ./scripts/cqi/routing/copyPublicFiles.sh",
    "updatePackages:major": "bunx taze major --includeLocked --maturity-period 5 --write && bun install",
    "updatePackages:minor": "bunx taze minor --includeLocked --maturity-period 5 --write && bun install",
    "bleach": "rm -rf node_modules/.astro && rm -rf node_modules/.bin && rm -rf node_modules/.vite && rm -rf .astro/ && rm -rf .netlify/ && rm -rf dist/ && bun install && bun run bleach:info",
    "bleach:info": "echo \"\u001B[43m\u001B[30m(!) Also delete the browser cache, see https://github.com/vitejs/vite/discussions/17738#discussioncomment-10158746\u001B[0m\"",
    "bleach:all": "rm -rf node_modules/ && bun run bleach",
    "bleach:full": "rm -f bun.lock package-lock.json && bun run bleach:all",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/netlify": "^7.0.13",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/ts-plugin": "^1.10.9",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@keystatic/astro": "^5.1.0",
    "@keystatic/core": "0.5.50",
    "@nanostores/react": "^1.1.0",
    "@nanostores/router": "^1.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.1",
    "@turf/turf": "^7.3.5",
    "@types/geojson": "^7946.0.16",
    "astro": "^6.4.8",
    "astro-heroicons": "^2.1.5-1",
    "date-fns": "^4.4.0",
    "maplibre-gl": "^5.24.0",
    "nanostores": "^1.3.0",
    "pmtiles": "^4.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-map-gl": "8.1.1",
    "remark-toc": "^9.0.0",
    "route-snapper": "^0.4.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tiny-invariant": "^1.3.3",
    "typescript": "^6.0.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "husky": "^9.1.7",
    "oxlint": "1.71.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.12",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "overrides": {
    "@keystatic/astro": {
      "astro": "$astro"
    }
  }
}
